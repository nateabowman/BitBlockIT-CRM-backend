{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nestjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/entry" }],
  "functions": {
    "api/entry.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "dist/**"
    }
  }
}
