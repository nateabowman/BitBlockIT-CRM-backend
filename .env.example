DATABASE_URL="postgresql://crm:crm_secret@localhost:5432/bitblockit_crm"
# Required: generate with: openssl rand -base64 32 (min 32 chars in production)
JWT_SECRET="your-generated-secret-here"
FRONTEND_URL="http://localhost:3000"
# Public URL of the API (links in emails, forms, tracking; default derived from FRONTEND_URL or host)
# API_PUBLIC_URL=https://crmapi.bitblockit.com
# Used in invite links (defaults to FRONTEND_URL)
# APP_URL=https://crm.bitblockit.com
# Comma-separated origins for CORS (production: https://crm.bitblockit.com is allowed by default)
# ALLOWED_ORIGINS=https://crm.bitblockit.com
PORT=3001
# Required for POST /api/v1/webhooks/leads (Zapier/Make); generate with: openssl rand -base64 32
WEBHOOK_LEADS_SECRET="your-webhook-secret-here"
# Optional: if set, /metrics requires x-metrics-token header (for Prometheus in production)
METRICS_SECRET=""
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BitBlockIT CRM <noreply@bitblockit.com>"
# Optional: use Resend/SendGrid/Mailgun instead of SMTP (one of these can replace SMTP_*)
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# Optional: base URL for "Schedule a meeting" links in email templates
# SCHEDULE_MEETING_URL=
# Optional: Slack webhook for outbound notifications (lead.created, lead.stage_changed)
# SLACK_WEBHOOK_URL=

# Redis (optional - for Apollo enrichment queue and campaign send queue; default redis://localhost:6379)
# REDIS_URL=redis://localhost:6379
# Optional: campaign email throttle (emails per minute)
# EMAIL_THROTTLE_PER_MINUTE=
# Optional: base URL for open/click tracking links (defaults to API_PUBLIC_URL)
# TRACKING_BASE_URL=

# bitblock-billing (optional - sync customer when Organization type is customer)
# BILLING_API_URL=https://billing.example.com
# BILLING_API_KEY=bb_billing_your_secret_key
# BILLING_WEBHOOK_SECRET=shared-secret-for-inbound-billing-webhook

# Apollo.io REST API (optional - for enrichment, outbound sequences, deals)
# APOLLO_API_KEY=
# APOLLO_MASTER_API_KEY=  # optional; for Deals/Sequences; defaults to APOLLO_API_KEY
# APOLLO_ENRICH_INBOUND_LEADS=false  # queue enrichment job when webhook creates lead

# OpenAI (optional - AI email subject/body generation)
# OPENAI_API_KEY=

# Revenue Intelligence API (optional - external service; requires x-revenue-intelligence-key header)
# REVENUE_INTELLIGENCE_API_KEY=

# Preference center (optional - override URL for unsubscribe/preference links; defaults to FRONTEND_URL/API_PUBLIC_URL)
# PREFERENCE_CENTER_URL=

# Twilio (optional - click-to-call and SMS for leads)
# TWILIO_ACCOUNT_SID=           # Account SID from Twilio Console
# TWILIO_AUTH_TOKEN=            # Auth Token from Twilio Console
# TWILIO_PHONE_NUMBER=          # E.164 (e.g. +15551234567)
# TWILIO_STATUS_CALLBACK_BASE_URL=  # public base URL Twilio can reach (e.g. https://crmapi.bitblockit.com); voice webhooks must return 200 + TwiML
# TWILIO_INBOUND_FORWARD_NUMBER=    # optional; E.164 number to forward inbound calls to (else plays message and hangs up)
# TWILIO_TWIML_APP_SID=         # TwiML App SID (for browser/WebRTC calling)
# TWILIO_API_KEY_SID=           # API Key SID (for browser token)
# TWILIO_API_KEY_SECRET=        # API Key Secret (for browser token)

# Sentry (Error tracking + Discord notifications)
# SENTRY_DSN=
# SENTRY_DISCORD_WEBHOOK_URL=  # or DISCORD_WEBHOOK_URL
